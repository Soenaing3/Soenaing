<!DOCTYPE html>
<html lang="my">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Myanmar Traditional Calendar</title>
    <style>
        :root { --primary: #6A1B9A; --secondary: #ffd54f; --yatyaza: #e8f5e9; --pyathada: #ffebee; }
        body { font-family: 'Pyidaungsu', sans-serif; margin: 0; background: #eee; }
        .app-container { max-width: 450px; margin: auto; background: white; min-height: 100vh; display: flex; flex-direction: column; }
        
        /* Header */
        .header { background: var(--primary); color: white; padding: 15px; text-align: center; }
        .naga-box { background: var(--secondary); padding: 10px; font-size: 13px; text-align: center; font-weight: bold; border-bottom: 2px solid #fbc02d; }
        
        /* Navigation */
        .nav { display: flex; justify-content: space-between; align-items: center; padding: 10px; background: #f5f5f5; }
        .nav-btn { background: var(--primary); color: white; border: none; padding: 5px 12px; border-radius: 4px; cursor: pointer; }

        /* Calendar Table */
        table { width: 100%; border-collapse: collapse; }
        th { padding: 10px; font-size: 11px; background: #fdfdfd; border-bottom: 1px solid #ddd; }
        td { width: 14.2%; height: 85px; text-align: center; border: 0.5px solid #f0f0f0; vertical-align: top; padding: 4px; transition: 0.3s; }
        
        .eng-day { font-size: 18px; font-weight: bold; display: block; }
        .mm-day { font-size: 10px; color: #555; display: block; margin-top: 2px; }
        .tag { font-size: 9px; font-weight: bold; display: block; margin-top: 5px; padding: 2px; border-radius: 3px; }

        /* Status Colors */
        .yatyaza { background: var(--yatyaza); color: #2e7d32; }
        .pyathada { background: var(--pyathada); color: #c62828; }
        .today { background: #f3e5f5; outline: 2px solid var(--primary); z-index: 1; }
        .sun { color: red; } .sat { color: blue; }

        /* Bottom Menu */
        .footer { margin-top: auto; display: flex; justify-content: space-around; padding: 12px; border-top: 1px solid #ddd; font-size: 12px; }
    </style>
</head>
<body>

<div class="app-container">
    <div class="header">
        <h2 id="mmYearDisplay">မြန်မာသက္ကရာဇ် ၁၃၈၇ ခု</h2>
    </div>

    <div class="naga-box" id="nagaDisplay">နဂါးခေါင်း - အရှေ့သို့လှည့်</div>

    <div class="nav">
        <button class="nav-btn" onclick="moveMonth(-1)">◀</button>
        <span id="monthYearDisplay" style="font-weight:bold"></span>
        <button class="nav-btn" onclick="moveMonth(1)">▶</button>
    </div>

    <table>
        <thead>
            <tr>
                <th class="sun">တနင်္ဂနွေ</th><th>တနင်္လာ</th><th>အင်္ဂါ</th><th>ဗုဒ္ဓဟူး</th><th>ကြာသပတေး</th><th>သောကြာ</th><th class="sat">စနေ</th>
            </tr>
        </thead>
        <tbody id="calendarBody"></tbody>
    </table>

    <div class="footer">
        <span>🟢 ရက်ရာဇာ</span>
        <span>🔴 ပြဿဒါး</span>
        <span>🐲 နဂါးခေါင်း</span>
    </div>
</div>

<script>
    let current = new Date();
    let m = current.getMonth();
    let y = current.getFullYear();

    const mmNums = ["၀", "၁", "၂", "၃", "၄", "၅", "၆", "၇", "၈", "၉"];
    const mmMonths = ["ဇန်နဝါရီ", "ဖေဖော်ဝါရီ", "မတ်", "ဧပြီ", "မေ", "ဇွန်", "ဇူလိုင်", "သြဂုတ်", "စက်တင်ဘာ", "အောက်တိုဘာ", "နိုဝင်ဘာ", "ဒီဇင်ဘာ"];

    function toMm(n) { return n.toString().split('').map(x => mmNums[parseInt(x)] || x).join(''); }

    // ပြဿဒါး နှင့် ရက်ရာဇာ တွက်ချက်မှု (ဗေဒင်ကျမ်းအလိုအရ အခြေခံတွက်ချက်မှု)
    function checkStatus(dayOfWeek, dayOfMonth) {
        // သာမန်အားဖြင့် တွက်ချက်မှုပုံစံ (နမူနာ)
        const pyathadaMap = { 5: [1, 6, 11, 16], 1: [2, 7, 12, 17], 4: [3, 8, 13, 18] };
        if (pyathadaMap[dayOfWeek] && pyathadaMap[dayOfWeek].includes(dayOfMonth % 20)) return { text: "ပြဿဒါး", class: "pyathada" };
        if (dayOfWeek === 2 || dayOfWeek === 4) return { text: "ရက်ရာဇာ", class: "yatyaza" };
        return null;
    }

    // နဂါးခေါင်းလှည့် တွက်ချက်မှု
    function getNagaDirection(month) {
        if (month >= 3 && month <= 5) return "🐲 နဂါးခေါင်း အရှေ့လှည့် (အနောက်မသွားအပ်)";
        if (month >= 6 && month <= 8) return "🐲 နဂါးခေါင်း တောင်လှည့် (မြောက်မသွားအပ်)";
        if (month >= 9 && month <= 11) return "🐲 နဂါးခေါင်း အနောက်လှည့် (အရှေ့မသွားအပ်)";
        return "🐲 နဂါးခေါင်း မြောက်လှည့် (တောင်မသွားအပ်)";
    }

    function initCalendar() {
        const body = document.getElementById("calendarBody");
        const monthLabel = document.getElementById("monthYearDisplay");
        const nagaLabel = document.getElementById("nagaDisplay");
        
        body.innerHTML = "";
        monthLabel.innerText = `${mmMonths[m]} ${toMm(y)}`;
        nagaLabel.innerText = getNagaDirection(m);

        let firstDay = new Date(y, m, 1).getDay();
        let totalDays = new Date(y, m + 1, 0).getDate();

        let row = document.createElement("tr");
        for (let i = 0; i < firstDay; i++) row.appendChild(document.createElement("td"));

        for (let day = 1; day <= totalDays; day++) {
            if ((firstDay + day - 1) % 7 === 0 && day !== 1) {
                body.appendChild(row);
                row = document.createElement("tr");
            }

            let cell = document.createElement("td");
            let dayOfWeek = (firstDay + day - 1) % 7;
            let status = checkStatus(dayOfWeek, day);

            if (day === current.getDate() && m === current.getMonth() && y === current.getFullYear()) cell.className = "today";
            
            let mmDateText = (day % 15 === 0) ? "လပြည့်" : (day % 15 < 8 ? "ဆန်း " + toMm(day % 15) : "ဆုတ် " + toMm(day % 15));
            let statusHTML = status ? `<span class="tag ${status.class}">${status.text}</span>` : "";

            cell.innerHTML = `
                <span class="eng-day ${dayOfWeek === 0 ? 'sun' : (dayOfWeek === 6 ? 'sat' : '')}">${toMm(day)}</span>
                <span class="mm-day">${mmDateText}</span>
                ${statusHTML}
            `;
            row.appendChild(cell);
        }
        body.appendChild(row);
    }

    function moveMonth(step) { m += step; if(m<0){ m=11; y--; } if(m>11){ m=0; y++; } initCalendar(); }
    initCalendar();
</script>

</body>
</html>
